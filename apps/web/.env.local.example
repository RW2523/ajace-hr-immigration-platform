# Supabase project: procurement-intel
NEXT_PUBLIC_SUPABASE_URL=https://coaszrosqlhifcwxurwu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_nO8n5IxHIdrZSYf6WN5Ixw_vlRcUOOl

# Service-role key (server-only; enables reliable signed URLs + server uploads).
# Optional — without it, storage falls back to the session client (org-scoped by RLS).
# Get it from Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection for the server-side data layer. Use the Supabase
# pooler/direct connection string WITH your database password:
#   postgres://postgres.coaszrosqlhifcwxurwu:[DB_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# App-layer PII encryption key (SSN/W-4). Generate: openssl rand -base64 32
PII_ENCRYPTION_KEY=

# LLM (OpenRouter) + embeddings — optional for the assistant.
OPENROUTER_API_KEY=
EMBEDDINGS_API_KEY=

# Show the demo-account list on the login page (leave unset/0 in production)
NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS=1
