# =============================================================================
# HR & IMMIGRATION platform (Next.js monorepo) — production environment
# Set these in the Vercel project (Settings → Environment Variables).
# Vercel project "Root Directory" MUST be set to:  apps/web
# (Vercel installs the pnpm workspace from the repo root and builds apps/web.)
#
# Two DATABASE_URLs matter:
#   • RUNTIME  → the Supabase TRANSACTION pooler (port 6543) — serverless-safe.
#   • MIGRATE  → the Supabase DIRECT / session connection (port 5432) — for DDL.
#     The migrate connection is used by CI (see .github/workflows/db-migrate.yml),
#     NOT set on Vercel.
# =============================================================================

# ---- Supabase (shared project: coaszrosqlhifcwxurwu) ------------------------
# Runtime reads only the NEXT_PUBLIC_ vars + the service-role key.
NEXT_PUBLIC_SUPABASE_URL=https://coaszrosqlhifcwxurwu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_nO8n5IxHIdrZSYf6WN5Ixw_vlRcUOOl
# Server-only; RLS-bypassing. From Supabase → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database (RUNTIME = transaction pooler, port 6543) ---------------------
# postgres://postgres.coaszrosqlhifcwxurwu:[DB_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ---- Application-layer PII encryption (SSN / W-4 / passport) ----------------
# 32-byte base64 key. Generate: openssl rand -base64 32
# Encryption FAILS CLOSED if unset — required.
PII_ENCRYPTION_KEY=

# ---- LLM (OpenRouter) + embeddings -----------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-5
# Optional: set OPENAI_API_KEY (+ OPENAI_BASE_URL / OPENAI_MODEL) to use a direct
# OpenAI-compatible provider for the assistant instead of OpenRouter.
# Embeddings: the OpenAI embedder is selected automatically when EMBEDDINGS_API_KEY is set.
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=1536
# Optional: point at a non-OpenAI, OpenAI-compatible embeddings endpoint
# (default https://api.openai.com/v1):
# EMBEDDINGS_BASE_URL=

# ---- Notifications (Resend) -------------------------------------------------
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=noreply@ajace.com
NOTIFICATIONS_PROD=1

# ---- Cron auth --------------------------------------------------------------
# Vercel Cron calls /api/cron/deadline-scan with this bearer. Generate: openssl rand -hex 32
CRON_SECRET=

# ---- App --------------------------------------------------------------------
APP_BASE_URL=https://immigration.ajace.com
# Hide the demo-account list on the login page in production.
NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS=0
