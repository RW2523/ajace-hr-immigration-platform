# ─── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (migrations, seed, tests).
# Local test DB (docker pgvector) default:
DATABASE_URL=postgres://postgres:postgres@localhost:54329/hr

# ─── Application-layer encryption ─────────────────────────────────────────
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
# Encrypts SSN / W-4 / passport columns on top of at-rest encryption (§12).
PII_ENCRYPTION_KEY=

# ─── LLM (OpenRouter) ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-5

# ─── Embeddings (OpenRouter has no embeddings endpoint — separate provider) ─
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=1536

# ─── Notifications ────────────────────────────────────────────────────────
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=noreply@example.com

# ─── App ──────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
